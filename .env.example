# =============================================================================
# Arc — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# OpenRouter (default for Kimi K2.5)
OPENROUTER_API_KEY=sk-or-v1-...

# Default model: Kimi K2.5 via OpenRouter
# OpenRouter identifier format: openrouter:provider/model-name
AGENT_MODEL=openrouter:moonshotai/kimi-k2.5

# Model configuration
AGENT_MAX_RETRIES=10
AGENT_TIMEOUT=120

# Alternative providers (uncomment to use):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# =============================================================================
# Cloud Persistence (Choose ONE)
# =============================================================================

# Option 1: Neon (Recommended - Easiest)
# Get your connection string from: https://neon.tech
# Format: postgres://user:password@host.neon.tech/dbname?sslmode=require
# NEON_DATABASE_URL=postgres://user:pass@host.neon.tech/dbname?sslmode=require

# Option 2: Cloudflare R2 (Best for file storage, zero egress fees)
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# CF_R2_ACCOUNT_ID=your_account_id
# CF_R2_ACCESS_KEY_ID=your_access_key
# CF_R2_SECRET_ACCESS_KEY=your_secret_key
# CF_R2_BUCKET_NAME=arc-agent
# CF_R2_PUBLIC_URL=https://your-custom-domain.com (optional)

# Option 3: Google Cloud SQL
# Setup: https://console.cloud.google.com/sql/instances
# GCP_DATABASE_URL=postgres://user:pass@<INSTANCE_IP>:5432/arc
# Or use these components:
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1
# GCP_INSTANCE_NAME=arc-postgres
# GCP_DB_USER=arc_user
# GCP_DB_PASSWORD=your_password
# GCP_DB_NAME=arc
# GCP_USE_PROXY=false (set to true for local development with Cloud SQL Proxy)

# Option 4: Local Only (default, no cloud persistence)
# Uses MemorySaver and local filesystem - data lost on restart

# =============================================================================
# Agent Mode Selection
# =============================================================================

# Set which agent configuration to use
# ARC_MODE=local       # Local filesystem + MemorySaver (default)
# ARC_MODE=neon        # Neon PostgreSQL backend
# ARC_MODE=gcp         # Google Cloud SQL backend
# ARC_MODE=r2          # Cloudflare R2 backend (requires custom backend)

# =============================================================================
# Workspace Configuration
# =============================================================================

WORKSPACE_ROOT=./workspace

# =============================================================================
# Web Search (required for researcher sub-agent)
# Get your key at: https://tavily.com
# =============================================================================
TAVILY_API_KEY=tvly-...

# =============================================================================
# LangSmith Observability (strongly recommended)
# Get your key at: https://smith.langchain.com
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=arc

# =============================================================================
# Backend Server
# =============================================================================
BACKEND_URL=http://localhost:8000

# =============================================================================
# Frontend (Next.js public env vars - must be prefixed NEXT_PUBLIC_)
# =============================================================================
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# =============================================================================
# Optional: Production Database (when not using cloud options above)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/arc
