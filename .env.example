# =============================================================================
# Arc — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider API Keys — provide at least one
# -----------------------------------------------------------------------------

# Anthropic (default model: claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative: openai:gpt-4o)
OPENAI_API_KEY=sk-...

# Google (alternative: google_genai:gemini-2.5-pro)
GOOGLE_API_KEY=AIza...

# Model to use for the main Arc agent
# Format: "provider:model-name"  (uses langchain init_chat_model)
AGENT_MODEL=anthropic:claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Web Search (required for the researcher sub-agent)
# Get your key at https://tavily.com
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# LangSmith Observability (strongly recommended for all environments)
# Get your key at https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=arc

# -----------------------------------------------------------------------------
# Backend server
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend (Next.js public env vars — must be prefixed NEXT_PUBLIC_)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database (production only — for LangGraph PostgreSQL checkpointer)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/arc
